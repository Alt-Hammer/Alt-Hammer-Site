---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import { ALLIANCES } from '../data/alliances.ts';
import { RULES_SECTIONS } from '../data/rules-nav.ts';
import { getCollection } from 'astro:content';

interface FactionFrontmatter {
  title: string;
  slug: string;
  alliance: string;
  status: 'active' | 'coming-soon';
  description?: string;
}

const factionPages = await Astro.glob('../content/factions/*.mdx');
const FACTIONS = factionPages
  .map((entry) => entry.frontmatter as FactionFrontmatter)
  .filter((frontmatter) => frontmatter?.slug)
  .sort((a, b) => a.title.localeCompare(b.title));

const factionsByAlliance = ALLIANCES.map((alliance) => ({
  alliance,
  factions: FACTIONS.filter((faction) => faction.alliance === alliance.id),
})).filter((group) => group.factions.length > 0);

const allianceColors: Record<string, string> = {
  imperium: '#c9a84c',
  chaos:    '#9b2020',
  aeldari:  '#3a7bd5',
  xenos:    '#2e8b57',
  devourer: '#7b3fa0',
};

// Load the Introduction section content from the rules collection
const rulesEntries = await getCollection('rules');
const introEntry = rulesEntries.find((e) => e.data.section === 'introduction');
const { Content: IntroContent } = introEntry ? await introEntry.render() : { Content: null };

// Tile accent colors — one per rules section, in nav order
const tileAccents = [
  'var(--color-gold)',  // Preparing Your Game
  '#c9a84c',           // The Battle Round
  '#3a7bd5',           // Actions & Activation Points
  '#5a8fd5',           // Model & Weapon Characteristics
  '#3a7bd5',           // Keywords & Abilities
  '#9b2020',           // Making Attacks
  '#7b3fa0',           // Psychic Attacks & Psykers
  '#8b2020',           // Battle Shock
  '#2e6b7b',           // Strategic Reserves
  '#8b2020',           // Command Points & Stratagems
  '#2e8b57',           // Generating a Battle
];

const tileIcons = [
  '◈', '◉', '⚡', '◎', '◈', '⚔', '✦', '◉', '◎', '▶', '◎',
];
---

<BaseLayout activePage="home">

  <!-- ── Hero ─────────────────────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-inner">
      <p class="hero-eyebrow animate-in">Community Rules Reference</p>
      <h1 class="hero-title animate-in animate-in-delay-1">
        <span class="title-main">Alt-Hammer</span>
        <span class="title-sub">40,000 · 1st Edition</span>
      </h1>
      <p class="hero-tagline animate-in animate-in-delay-2">
        An alternating-activations game system built on the bones of
        Warhammer 40,000. Faster. More tactical. Fully community-driven.
      </p>
      <div style="display:flex; gap:16px; justify-content:center; flex-wrap:wrap;"
           class="animate-in animate-in-delay-3">
        <a href="/rules/preparing-your-game" class="btn btn-primary">Read Core Rules</a>
        <a href="/factions" class="btn btn-ghost">Browse Factions</a>
      </div>

      <div class="divider-tactical animate-in animate-in-delay-4">
        Field Manual · 1st Edition · Community Build
      </div>
    </div>
  </section>

  <!-- ── Introduction ─────────────────────────────────────────────────── -->
  {IntroContent && (
    <section class="home-intro">
      <div class="home-intro-inner">
        <IntroContent />
      </div>
    </section>
  )}

  <!-- ── Core Rules Tiles ─────────────────────────────────────────────── -->
  <div class="home-section-header">
    <h2>Core Rules</h2>
    <a href="/rules/preparing-your-game" class="home-section-link">Browse all sections →</a>
  </div>

  <div class="card-grid">
    {RULES_SECTIONS.map((section, i) => (
      <a
        href={section.href}
        class="feature-card animate-in"
        style={`--card-accent: ${tileAccents[i] ?? 'var(--color-gold)'};`}
      >
        <span class="feature-card-icon">{tileIcons[i] ?? '◈'}</span>
        <div class="feature-card-title">{section.label}</div>
        <p class="feature-card-desc">
          {section.items.length > 0
            ? section.items.map((item) => item.label).join(' · ')
            : `Read the ${section.label} rules.`}
        </p>
      </a>
    ))}

    <a href="/list-builder" class="feature-card animate-in"
       style="--card-accent: #3a7bd5; opacity: 0.7;">
      <span class="feature-card-icon">☰</span>
      <div class="feature-card-title">
        List Builder
        <span class="badge badge-wip" style="margin-left:8px; vertical-align:middle;">
          Soon
        </span>
      </div>
      <p class="feature-card-desc">
        Build and validate army lists with automatic force organization
        enforcement, wargear constraints, and shareable list links.
      </p>
    </a>
  </div>

  <!-- ── Factions section ──────────────────────────────────────────────── -->
  <div style="padding: 0 24px 64px; max-width: 1100px; margin: 0 auto;">

    <div style="margin-bottom: 40px;">
      <h2 style="display:inline; font-size: 1.6rem;">Factions</h2>
      <span style="margin-left: 16px; font-family: var(--font-mono); font-size: 0.7rem;
                   color: var(--color-text-muted); letter-spacing: 0.15em; text-transform: uppercase;">
        {FACTIONS.filter(f => f.status === 'active').length} active
        · {FACTIONS.filter(f => f.status === 'coming-soon').length} coming soon
      </span>
    </div>

    {factionsByAlliance.map(({ alliance, factions }) => (
      <div>
        <div class="alliance-header"
             style={`--alliance-color: ${allianceColors[alliance.id] ?? 'var(--color-gold)'};`}>
          <span class="alliance-label">{alliance.label}</span>
          <div class="alliance-rule"></div>
        </div>

        <div class="faction-grid" style="margin-bottom: 8px;">
          {factions.map((faction) => (
            <a
              href={faction.status === 'active' ? `/factions/${faction.slug}` : '#'}
              class={`faction-card ${faction.status === 'coming-soon' ? 'coming-soon' : ''}`}
              style={`--alliance-color: ${allianceColors[faction.alliance] ?? 'var(--color-gold-dim)'};`}
            >
              <span class="faction-card-name">{faction.title}</span>
              {faction.description && (
                <span class="faction-card-desc">{faction.description}</span>
              )}
            </a>
          ))}
        </div>
      </div>
    ))}
  </div>

</BaseLayout>

<style>
  /* Homepage-specific overrides */
  .main-content {
    padding: 0;
    max-width: 100%;
  }

  /* Introduction prose block */
  .home-intro {
    max-width: 860px;
    margin: 0 auto;
    padding: 40px 24px 32px;
    border-bottom: 1px solid var(--color-border);
  }

  .home-intro-inner {
    font-size: 0.95rem;
    line-height: 1.75;
    color: var(--color-text-secondary);
  }

  .home-intro-inner h3 {
    font-size: 1rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-primary);
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
  }

  .home-intro-inner ol,
  .home-intro-inner ul {
    padding-left: 1.4rem;
    margin: 0.75rem 0;
  }

  .home-intro-inner li {
    margin-bottom: 0.4rem;
  }

  /* Core Rules section heading row */
  .home-section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    padding: 40px 24px 16px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .home-section-header h2 {
    font-size: 1.6rem;
    margin: 0;
  }

  .home-section-link {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-decoration: none;
    letter-spacing: 0.08em;
    white-space: nowrap;
    transition: color 0.15s;
  }

  .home-section-link:hover {
    color: var(--color-gold);
  }
</style>
