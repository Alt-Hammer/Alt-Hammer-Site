---
// src/pages/rules/missions.astro
import DocsLayout from '../../layouts/DocsLayout.astro';

const deploymentZones = [
  { roll: 1, name: 'Dawn Assault', desc: 'Attacker deploys along one short edge. Defender deploys along the opposite short edge. Deployment zones extend 12" in from each edge.' },
  { roll: 2, name: 'Hammer & Anvil', desc: 'Attacker deploys along one long edge. Defender deploys along the opposite long edge. Deployment zones extend 9" in from each edge.' },
  { roll: 3, name: 'Spearhead Assault', desc: 'Attacker and Defender deploy in diagonally opposite corners. Each deployment zone is a triangle 12" from the corner.' },
  { roll: 4, name: 'Search & Destroy', desc: 'Mirrored diagonal deployment. Attacker and Defender occupy opposite triangular corners, 18" from the board centre on their respective long edges.' },
  { roll: 5, name: 'Encirclement', desc: 'Defender deploys in a central zone 12" from all edges. Attacker deploys outside this zone, with units spread around the perimeter.' },
  { roll: 6, name: 'Front Lines', desc: 'Both players deploy along opposite long edges. Deployment zones extend 6" in, leaving a large No Man\'s Land in the centre.' },
];

const primaryObjectiveRules = [
  { roll: '1', name: 'Domination', desc: 'Score 3 VP at the end of each Battle Round for each Primary Objective Marker you control more than your opponent.' },
  { roll: '2', name: 'Scorched Earth', desc: 'Score 2 VP at the end of each Battle Round for each Primary Objective Marker you control. Additionally, you can use the Mission Task Action to destroy a Marker you control — you cannot re-capture it, but neither can your opponent.' },
  { roll: '3', name: 'Priority Targets', desc: 'Before the battle, each player secretly designates 1 Primary Objective Marker as their Priority Target. Score 4 VP at the end of each Battle Round you control your Priority Target.' },
  { roll: '4', name: 'Recover the Relics', desc: 'Score 2 VP at the end of each Battle Round for each Primary Objective Marker you control. A unit that uses the Mission Task Action on a Marker it controls adds a Relic token; that Marker is worth 4 VP instead of 2 for as long as you control it.' },
  { roll: '5', name: 'Data Uplink', desc: 'Units using the Mission Task Action within 6" of a Primary Objective Marker immediately grant 1 additional Command Point.' },
  { roll: '6', name: 'Fortified Position', desc: 'At the end of each Battle Round, units that Remained Stationary on a Primary Objective Marker for the entire round grant +1 OC to all friendly units on that objective until control is lost.' },
];

const secondaryObjectives = [
  { roll: '2',    name: 'Secure the Flank', timing: 'End of Activation', pts: '1 / 3',   desc: 'Unit ends its Activation wholly within 6" of a battlefield edge in No Man\'s Land (1 VP) or the enemy Deployment Zone (3 VP).' },
  { roll: '3',    name: 'Hold the Line',    timing: 'End of Battle Round', pts: '2',      desc: 'No enemy units wholly within your deployment zone at the end of the round.' },
  { roll: '4',    name: 'Sabotage',         timing: 'End of Activation',  pts: '3',      desc: 'A friendly unit uses the Mission Task Action within 3" of an enemy-controlled Objective. Only once per Objective Marker.' },
  { roll: '5',    name: 'Take Ground',      timing: 'End of Battle Round', pts: '3',      desc: 'Points awarded for each new Primary Objective Marker you control at the end of the Battle Round.' },
  { roll: '6',    name: 'Attrition',        timing: 'End of Battle Round', pts: '2 / 4', desc: 'Score 2 VP per 10 enemy models destroyed this round. Score 4 VP per 10 enemy Battleline models destroyed.' },
  { roll: '7',    name: 'Bring It Down',    timing: 'End of Battle Round', pts: '2/3/5', desc: 'Score VPs for destroying enemy Vehicle or Monster models: T1–9 = 2 VP, T10–12 = 3 VP, T13+ = 5 VP.' },
  { roll: '8',    name: 'Counterattack',    timing: 'End of Activation',  pts: '2 / 4', desc: 'Destroy models from an enemy unit that is or was in base contact with a friendly unit. Partial unit = 2 VP; entire unit = 4 VP.' },
  { roll: '9',    name: 'Defend the Strongpoint', timing: 'End of Battle Round', pts: '4', desc: 'Score 4 VP per friendly unit that Remained Stationary on a Primary Objective Marker in No Man\'s Land and still controls it at round\'s end.' },
  { roll: '10',   name: 'Breakthrough',     timing: 'End of Activation',  pts: '2',      desc: 'Score 2 VP each time a friendly unit ends its Activation wholly within the enemy Deployment Zone.' },
  { roll: '11',   name: 'Pin Down',         timing: 'End of Activation',  pts: '3',      desc: 'Score 3 VP each time a friendly unit\'s attacks cause an enemy unit to become Battle Shocked before being activated.' },
  { roll: '12',   name: 'Precision Strike', timing: 'End of Activation',  pts: '2/4/6', desc: 'Destroy an enemy Character = 2 VP; destroy a Leader with a Precision attack = 4 VP; destroy the enemy Warlord = 6 VP.' },
];
---

<DocsLayout
  title="Generating a Mission"
  description="Alt-Hammer 40,000 mission generation — board sizes, deployment zones, primary objectives, and secondary objectives."
  activePage="rules"
  sidebarType="rules"
>
  <div class="page-header">
    <p class="breadcrumb"><a href="/rules/core-rules">Rules</a></p>
    <h1>Generating a Mission</h1>
    <p class="subtitle">
      A standardised method for generating an Alt-Hammer battle from scratch.
      Use all sections, or any combination agreed upon by the players.
    </p>
  </div>

  <!-- Board Sizes -->
  <section id="board-size">
    <h2>Board Size &amp; Deployment Zones</h2>
    <p>Alt-Hammer battles are played on a tabletop board matching these dimensions as closely as possible:</p>
    <div class="data-table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th style="text-align:left;">Game Size</th>
            <th>Board Size</th>
          </tr>
        </thead>
        <tbody>
          {[
            ['500 points or less',    '24" × 36"'],
            ['501 – 1,000 points',    '36" × 48"'],
            ['1,001 – 2,000 points',  '48" × 72"'],
            ['2,001 – 3,000 points',  '48" × 96"'],
            ['Above 3,000 points',    'Custom'],
          ].map(([size, board]) => (
            <tr>
              <td class="row-header" style="text-align:left; padding-left:12px;">{size}</td>
              <td style="font-family:var(--font-mono); color:var(--color-gold);">{board}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- Attacker / Defender -->
  <section id="deployment-zones">
    <h2>Determine Attacker, Defender &amp; Deployment Zone</h2>
    <p>
      Each player rolls a D6. The highest roll is the <strong>Attacker</strong>.
      The Attacker then rolls a D6 to select the Deployment Zone:
    </p>
    <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(280px,1fr)); gap:12px; margin-top:24px;">
      {deploymentZones.map((dz) => (
        <div style="background:var(--color-surface-1); border:1px solid var(--color-border); padding:16px; position:relative;">
          <div style="position:absolute;top:12px;right:12px;font-family:var(--font-mono);font-size:1.2rem;font-weight:700;color:var(--color-gold);opacity:0.4;">{dz.roll}</div>
          <div style="font-family:var(--font-display);font-size:0.9rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--color-text-primary);margin-bottom:6px;">{dz.name}</div>
          <p style="font-size:0.85rem;color:var(--color-text-muted);margin:0;">{dz.desc}</p>
        </div>
      ))}
    </div>

    <h3 id="deploying-units" style="margin-top:40px;">Deploying Units</h3>
    <p style="color:var(--color-text-muted);font-style:italic;">
      [ Paste the full Deploying Units rules from your Core Rules document here. ]
    </p>
  </section>

  <!-- Primary Objectives -->
  <section id="primary-objectives">
    <h2>Primary Mission Objectives</h2>

    <h3>Determine Number of Objective Markers</h3>
    <p style="color:var(--color-text-muted);font-style:italic;">
      [ Paste the Objective Marker count rules from your Core Rules document here. ]
    </p>

    <h3>Holding Objectives</h3>
    <p style="color:var(--color-text-muted);font-style:italic;">
      [ Paste the Holding Objectives rules from your Core Rules document here. ]
    </p>

    <h3>Victory Points for Controlling Objectives</h3>
    <p style="color:var(--color-text-muted);font-style:italic;">
      [ Paste the Victory Points rules here. ]
    </p>
  </section>

  <!-- Mission Rules -->
  <section id="mission-rules">
    <h2>Optional: Mission Rules</h2>
    <p>
      Roll 1D6 at the start of the battle to determine the Mission Rule in effect.
      Mission Rules create special conditions that affect gameplay for the entire battle.
    </p>
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:12px; margin-top:20px;">
      {primaryObjectiveRules.map((r) => (
        <div style="background:var(--color-surface-1); border:1px solid var(--color-border); padding:16px; position:relative;">
          <div style="position:absolute;top:12px;right:12px;font-family:var(--font-mono);font-size:1.2rem;font-weight:700;color:var(--color-gold);opacity:0.4;">{r.roll}</div>
          <div style="font-family:var(--font-display);font-size:0.9rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--color-text-primary);margin-bottom:6px;">{r.name}</div>
          <p style="font-size:0.85rem;color:var(--color-text-muted);margin:0;">{r.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Secondary Objectives -->
  <section id="secondary-objectives">
    <h2>Optional: Secondary Mission Objectives</h2>
    <p>
      At the start of each Battle Round, each player rolls a D12 (or 2D6) three times.
      Each result indicates a Secondary Objective in effect for that player for the duration
      of the Battle Round.
    </p>
    <p>
      Uncompleted Secondary Objectives may be retained for the next Battle Round. Completed
      objectives must be replaced. If an objective is impossible to complete this round,
      the player may discard and re-roll once.
    </p>
    <div class="data-table-wrap" style="margin-top:24px;">
      <table class="data-table">
        <thead>
          <tr>
            <th>Roll</th>
            <th style="text-align:left;">Objective</th>
            <th style="text-align:left;">Timing</th>
            <th>VP</th>
            <th style="text-align:left;">Description</th>
          </tr>
        </thead>
        <tbody>
          {secondaryObjectives.map((s) => (
            <tr>
              <td style="font-family:var(--font-mono);font-weight:700;color:var(--color-gold);">{s.roll}</td>
              <td class="row-header" style="text-align:left;white-space:nowrap;">{s.name}</td>
              <td style="text-align:left;font-size:0.8rem;color:var(--color-text-muted);white-space:nowrap;">{s.timing}</td>
              <td style="font-family:var(--font-mono);color:var(--color-gold-bright);white-space:nowrap;">{s.pts}</td>
              <td style="text-align:left;font-family:var(--font-body);font-size:0.85rem;color:var(--color-text-secondary);">{s.desc}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

</DocsLayout>
