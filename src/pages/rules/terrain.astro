---
// src/pages/rules/terrain.astro
import DocsLayout from '../../layouts/DocsLayout.astro';

const terrainAttributes = [
  {
    id: 'light-cover',
    name: 'Light Cover',
    effects: [
      'Models making Ranged attacks against models wholly positioned in this terrain reduce their Hit roll by 1.',
      'Reduce the Armour Piercing characteristic of Ranged attacks by 1 against models wholly within this terrain.',
    ],
  },
  {
    id: 'heavy-cover',
    name: 'Heavy Cover',
    effects: [
      'Models making Ranged attacks against models wholly in Heavy Cover — or wholly behind it — reduce their Hit roll by 1.',
      'Reduce the Armour Piercing characteristic of Ranged attacks by 2 against models wholly within Heavy Cover.',
    ],
  },
  {
    id: 'vantage-points',
    name: 'Vantage Points',
    effects: [
      'Must be applied to any terrain feature where models can be positioned more than 5" vertically above ground level.',
      'Models making Ranged attacks from a Vantage Point add 1 to their Hit rolls when attacking units at ground level.',
    ],
  },
  {
    id: 'difficult-ground',
    name: 'Difficult Ground',
    effects: [
      'Models that move into, out of, or through Difficult Ground reduce their Movement characteristic by 1".',
      'Has no effect for models with the Fly, Jump Pack, Hover, Phase Shift, or Aircraft keywords.',
    ],
  },
  {
    id: 'impassable',
    name: 'Impassable',
    effects: [
      'Impassable terrain cannot be moved over or through by any model.',
      'Does not apply to models with the Phase Shift or Aircraft keywords.',
      'The vertical height of the terrain should be factored in when moving models with keywords that allow them to ignore certain heights.',
    ],
  },
  {
    id: 'obscuring',
    name: 'Obscuring',
    effects: [
      'Terrain features at least 12" tall relative to ground level are Obscuring.',
      'Models cannot be the target of Ranged attacks if they are wholly behind Obscuring terrain relative to the attacker.',
      'Titanic models cannot benefit from Obscuring while any part of the model is visible.',
    ],
  },
  {
    id: 'exposed-position',
    name: 'Exposed Position',
    effects: [
      'Terrain features — or parts of terrain features — more than 5" tall with little protective features should have this keyword.',
      'Models making Ranged attacks against models in Exposed Positions add 1 to their Hit rolls.',
    ],
  },
  {
    id: 'defensible-position',
    name: 'Defensible Position',
    effects: [
      'Models positioned within a Defensible Position treat models within 2" as being in Base-to-Base contact.',
      'Models that Charge and Fight models wholly within a Defensible Position terrain feature reduce their Initiative by 1.',
    ],
  },
];

const terrainTypes = [
  { name: 'Hill', keywords: ['None (is ground level)'], notes: 'Hills are considered part of the battlefield\'s ground level. Other terrain can be placed on Hills. Plain hills at least 5" high with discernible obscuring elements should possess the Exposed Position keyword.' },
  { name: 'Building', keywords: ['Heavy Cover', 'optionally: Defensible Position, Obscuring, Vantage Points'], notes: 'Always possess Heavy Cover (never Light Cover). Taller buildings with 2+ storeys should have Obscuring and Vantage Points.' },
  { name: 'Ruins', keywords: ['Difficult Ground', 'optionally: Obscuring, Vantage Points'], notes: 'Damaged buildings with the Ruins keyword. Always possess Difficult Ground. Taller ruins with 2+ storeys should have Obscuring and Vantage Points.' },
  { name: 'Forest', keywords: ['Light Cover', 'Difficult Ground'], notes: 'Always possess Light Cover and Difficult Ground. Can never possess Heavy Cover.' },
  { name: 'Craters', keywords: ['Difficult Ground', 'optionally: Light Cover'], notes: 'Always include Difficult Ground. Can possess Light Cover but never Heavy Cover.' },
  { name: 'Linear Low-lying Features', keywords: ['Light Cover', 'Defensible Position'], notes: 'Barricades, pipes, fences, etc. Should not exceed 2" in height or 3" in width/depth.' },
];
---

<DocsLayout
  title="Terrain"
  description="Alt-Hammer 40,000 terrain attribute keywords, terrain types, and their effects on gameplay."
  activePage="rules"
  sidebarType="rules"
>
  <div class="page-header">
    <p class="breadcrumb"><a href="/rules/core-rules">Rules</a></p>
    <h1>Terrain Attributes &amp; Types</h1>
    <p class="subtitle">
      Terrain features in Alt-Hammer use keywords to define their gameplay effects.
      Before each battle, players agree which keywords apply to each terrain feature on the table.
    </p>
  </div>

  <section id="terrain-attributes">
    <h2>Terrain Attribute Keywords</h2>
    <p>
      Every terrain feature should possess at least 1 Terrain Attribute keyword. These
      keywords specify how models interact with the terrain and what benefits or drawbacks
      it provides. Players should establish terrain attributes before the battle begins.
    </p>

    {terrainAttributes.map((attr) => (
      <div id={attr.id} style="margin-bottom:32px;">
        <h3>{attr.name}</h3>
        <ul>
          {attr.effects.map((effect) => <li>{effect}</li>)}
        </ul>
      </div>
    ))}
  </section>

  <section id="terrain-types">
    <h2>Terrain Types</h2>
    <p>
      The following standard Terrain Types are recommended for Alt-Hammer battlefields.
      Each Terrain Type is also its own keyword, which may interact with Faction rules and
      unit abilities.
    </p>
    <div class="data-table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th style="text-align:left;">Terrain Type</th>
            <th style="text-align:left;">Standard Keywords</th>
            <th style="text-align:left;">Notes</th>
          </tr>
        </thead>
        <tbody>
          {terrainTypes.map((t) => (
            <tr>
              <td class="row-header" style="text-align:left; white-space:nowrap;">{t.name}</td>
              <td style="text-align:left; font-family:var(--font-mono); font-size:0.75rem; color:var(--color-text-secondary);">
                {t.keywords.join(', ')}
              </td>
              <td style="text-align:left; font-family:var(--font-body); font-size:0.85rem; color:var(--color-text-muted);">
                {t.notes}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

</DocsLayout>
