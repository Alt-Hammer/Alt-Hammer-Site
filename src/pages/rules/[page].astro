---
import DocsLayout from '../../layouts/DocsLayout.astro';
import { RULES_SECTIONS } from '../../data/rules-nav.ts';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const rulePages = await getCollection('rules');
  const sections = Array.from(
    new Set(
      rulePages
        .map((entry) => entry.data.section)
        .filter((section) => typeof section === 'string')
    )
  );
  return sections.map((section) => ({
    params: { page: section },
  }));
}

const page = Astro.params.page;
const section = RULES_SECTIONS.find((item) => item.href === `/rules/${page}`);
if (!section) {
  throw new Error(`Unknown rules page: ${page}`);
}

const rulePages = await getCollection('rules');
const matchingPages = rulePages
  .filter((entry) => entry.data.section === page)
  .sort((a, b) => (a.id || '').localeCompare(b.id || ''));

if (matchingPages.length === 0) {
  throw new Error(`No rule content found for ${page}`);
}

const pageTitle = section.label;
const pageDescription = matchingPages[0]?.data.description ?? `${section.label} for Alt-Hammer 40,000.`;

const renderedPages = await Promise.all(
  matchingPages.map(async (entry) => {
    const { Content } = await entry.render();
    return Content;
  })
);
---

<DocsLayout
  title={pageTitle}
  description={pageDescription}
  activePage="rules"
  sidebarType="rules"
>
  <div class="page-header">
    <p class="breadcrumb">Rules</p>
    <h1>{pageTitle}</h1>
    <p class="subtitle">
      {pageDescription}
    </p>
  </div>

  {renderedPages.map((Content) => <Content />)}
</DocsLayout>